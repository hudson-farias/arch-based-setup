#!/usr/bin/env python3

import json
from pathlib import Path

MANIFEST = Path.home() / ".config/VSCodium/User/profiles-manifest.json"
STORAGE = Path.home() / ".config/VSCodium/User/globalStorage/storage.json"


def main() -> None:
    if not MANIFEST.is_file():
        return

    profiles = json.loads(MANIFEST.read_text())
    STORAGE.parent.mkdir(parents=True, exist_ok=True)

    if STORAGE.is_file():
        storage = json.loads(STORAGE.read_text())
    else:
        storage = {}

    storage["userDataProfiles"] = profiles
    STORAGE.write_text(json.dumps(storage, indent=4) + "\n")


if __name__ == "__main__":
    main()
